#Chapter 18 - Creating Re-useable sessions
Invoke-Command -ComputerName Server22-01 -ScriptBlock {
    $env:COMPUTERNAME
    Hostname
    get-process -Name n*
}
    
    Enter-PSSession -ComputerName server22-01  #Will create a 1:1 connection
    Exit-PSSession
    
    #Creating reusable sessions - Desirsable to store the session in a variable
    $Ses = New-PSSession -ComputerName server22-01, Win11-Client
    Get-PSSession
    
    Enter-PSSession -id 7
    Exit-PSSession
    
    Invoke-Command -Session $Ses -ScriptBlock {hostname}
    
    $Ses | Where-Object ComputerName -eq "Server22-01" | Enter-PSSession
    #OR

    Enter-PSSession -Session ($ses | Where-Object computername -eq 'Server22-01')
    
    Invoke-Command -Session $ses -ScriptBlock {
        Get-CimInstance -classname Win32_LogicalDisk -filter "drivetype=3" | 
        Sort-Object -property DeviceID|
        Select-Object -property DeviceID,
        @{name='FreeSpace(MB)';expression={$_.FreeSpace / 1MB -as [int]}},
        @{name='Size(GB';expression={$_.Size / 1GB -as [int]}},
        @{name='%Free';expression={$_.FreeSpace / $_.Size * 100 -as [int]}}
    }
    

    #Implicit Remoting
    $ServerSes = New-PSSession -ComputerName Server22-01
    
    #Import commands from a remote computer/session
    #Commands remain available until close session or shell
    #Executing these commands causes them to be executed on remote system and send back results
    #The objects returned are deserialized.  (We get object info not methods)
    Import-PSSession -Module servermanager -Session $ServerSes -Prefix rem
    get-command -noun "rem*"
    
    Get-remWindowsFeature  #access features on Server22-01
    Get-WindowsFeature #access features on local server
    
    #Complete on Server22-02 (Member Server)
    $sessions = New-PSSession -ComputerName server22-01
    Invoke-Command -Session $sessions -ScriptBlock {
        Get-Command -Module activedirectory
    }
    
    Import-PSSession -Session $sessions -Module activedirectory -Prefix rem2
    gcm -Noun rem*
    
    Get-remADUser -Filter *
    
    Get-PSSession | Remove-PSSession
    
    $sessions | Remove-PSSession
